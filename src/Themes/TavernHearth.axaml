<!-- Tavern Hearth — parchment & ink; reading an ancient map by candlelight.
     A flat theme: one set of colours, no Dark/Light variants. The host
     applies these regardless of the active Avalonia variant. -->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Surfaces — parchment ladder -->
    <SolidColorBrush x:Key="SidebarBackground"      Color="#E8D9B8" />
    <SolidColorBrush x:Key="ContentBackground"      Color="#F5E9D3" />
    <SolidColorBrush x:Key="PanelBackground1"       Color="#EDDFC1" />
    <SolidColorBrush x:Key="PanelBackground2"       Color="#F5E9D3" />
    <SolidColorBrush x:Key="PanelBackground3"       Color="#DBCBA7" />
    <SolidColorBrush x:Key="SubtleBorder"           Color="#B8A687" />

    <!-- Accents — vintage ruby (ink stamp) + forest green -->
    <SolidColorBrush x:Key="PrimaryAccent"          Color="#8B1A1A" />
    <SolidColorBrush x:Key="PrimaryAccentHover"     Color="#A52A2A" />
    <SolidColorBrush x:Key="OnPrimaryAccent"        Color="#F5E9D3" />
    <SolidColorBrush x:Key="SecondaryAccent"        Color="#2D5016" />

    <!-- Text — walnut ink + faded sepia -->
    <SolidColorBrush x:Key="TextPrimary"            Color="#3D2817" />
    <SolidColorBrush x:Key="TextSecondary"          Color="#6F5A3F" />

    <!-- Status pairs — tavern hues -->
    <SolidColorBrush x:Key="SuccessBackground"      Color="#DCE5C8" />
    <SolidColorBrush x:Key="SuccessForeground"      Color="#2D5016" />
    <SolidColorBrush x:Key="DangerBackground"       Color="#E5C8C8" />
    <SolidColorBrush x:Key="DangerForeground"       Color="#8B1A1A" />
    <SolidColorBrush x:Key="InfoBackground"         Color="#D8DBE0" />
    <SolidColorBrush x:Key="InfoForeground"         Color="#3D5A75" />
    <SolidColorBrush x:Key="WarningBackground"      Color="#F0DDB8" />
    <SolidColorBrush x:Key="WarningForeground"      Color="#8B5A1A" />

    <!-- Composition keys -->
    <SolidColorBrush x:Key="DropZoneHighlight"      Color="#B48B1A1A" />
    <SolidColorBrush x:Key="WaveformBrush"          Color="#8B1A1A" />
    <SolidColorBrush x:Key="LoopInheritForeground"  Color="#6F5A3F" />
    <SolidColorBrush x:Key="LoopForceOnForeground"  Color="#2D5016" />
    <SolidColorBrush x:Key="LoopForceOffForeground" Color="#8B1A1A" />
</ResourceDictionary>